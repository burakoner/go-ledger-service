  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "// Generate a UUID (GUID) per request and attach as X-Request-Id header\r",
          "function uuidv4() {\r",
          "    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function (c) {\r",
          "        const r = Math.random() * 16 | 0;\r",
          "        const v = (c === 'x') ? r : (r & 0x3 | 0x8);\r",
          "        return v.toString(16);\r",
          "    });\r",
          "}\r",
          "\r",
          "// Upsert header so it works whether header exists or not\r",
          "const requestId = uuidv4();\r",
          "pm.request.headers.upsert({\r",
          "    key: \"X-Request-Id\",\r",
          "    value: requestId\r",
          "});"
        ]
      }
    },
